

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or "mysql", "sqlite", "sqlserver", "mongodb"
  url      = env("DATABASE_URL")
}

// ===================
// ENUMS
// ===================

enum Role {
  SUPERADMIN
  ADMIN
  CUSTOMER
  SELLER
}

enum DealStatus {
  PRE_OPEN
  OPEN
  COMPLETED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum Method {
  QR
  TRANSFER
  CARD
}

// ===================
// MODELS
// ===================

model User {
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  password       String
  role           Role      @default(CUSTOMER)
  birth_date     DateTime?
  trust_score_id Int?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // Relations
  notifications   NotificationTable[]
  waitlists       Waitlist[]
  trustScores     TrustScore[]
  joins           Join[]
  createdDeals    Deal[]              @relation("CreatedDeals")
  updatedDeals    Deal[]              @relation("UpdatedDeals")
  createdTiers    Tier[]              @relation("CreatedTiers")
  updatedTiers    Tier[]              @relation("UpdatedTiers")
  createdPayments Payment[]

  @@map("users")
}

model Seller {
  id           Int      @id @default(autoincrement())
  name         String
  contact_info String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  deals Deal[]

  @@map("sellers")
}

model Category {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  deals Deal[]

  @@map("categories")
}

model Deal {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  image_url   String?
  deal_status DealStatus @default(PRE_OPEN)
  start_at    DateTime
  deadline    DateTime
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  // Foreign Keys
  category_id Int
  seller_id   Int
  creator     Int
  updater     Int?

  // Relations
  category      Category   @relation(fields: [category_id], references: [id])
  seller        Seller     @relation(fields: [seller_id], references: [id])
  createdByUser User       @relation("CreatedDeals", fields: [creator], references: [id])
  updatedByUser User?      @relation("UpdatedDeals", fields: [updater], references: [id])
  tiers         Tier[]
  joins         Join[]
  waitlists     Waitlist[]

  @@map("deals")
}

model Tier {
  id               Int      @id @default(autoincrement())
  min_participants Int
  price            Float
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Foreign Keys
  deal_id Int
  creator Int
  updater Int?

  // Relations
  deal          Deal  @relation(fields: [deal_id], references: [id])
  createdByUser User  @relation("CreatedTiers", fields: [creator], references: [id])
  updatedByUser User? @relation("UpdatedTiers", fields: [updater], references: [id])

  @@map("tiers")
}

model Join {
  id                   Int       @id @default(autoincrement())
  participation_status String // Consider making this an enum e.g., JOINED, CANCELLED
  max_participants     Int
  notes                String?
  joined_at            DateTime  @default(now())
  confirm_at           DateTime?
  paid_at              DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  // Foreign Keys
  user_id Int
  deal_id Int

  // Relations
  user    User     @relation(fields: [user_id], references: [id])
  deal    Deal     @relation(fields: [deal_id], references: [id])
  payment Payment?

  @@map("joins")
}

model Payment {
  id             Int           @id @default(autoincrement())
  amount         Float
  method         Method
  payment_status PaymentStatus @default(PENDING)
  created_at     DateTime      @default(now())

  // Foreign Keys
  join_id Int @unique // One-to-one with Join
  creator Int

  // Relations
  join            Join             @relation(fields: [join_id], references: [id])
  createdByUser   User             @relation(fields: [creator], references: [id])
  transactionLogs TransactionLog[]

  @@map("payments")
}

model TransactionLog {
  id         Int      @id @default(autoincrement())
  amount     Float
  status     String
  notes      String?
  created_at DateTime @default(now())

  // Foreign Keys
  payment_id Int

  // Relations
  payment Payment @relation(fields: [payment_id], references: [id])

  @@map("transaction_logs")
}

model Waitlist {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Foreign Keys
  user_id Int
  deal_id Int

  // Relations
  user User @relation(fields: [user_id], references: [id])
  deal Deal @relation(fields: [deal_id], references: [id])

  @@unique([user_id, deal_id])
  @@map("waitlists")
}

model TrustScore {
  id         Int      @id @default(autoincrement())
  change     Int
  reason     String
  created_at DateTime @default(now())

  // Foreign Keys
  user_id Int

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@map("trust_scores")
}

model NotificationTable {
  id         Int       @id @default(autoincrement())
  title      String
  message    String
  read_at    DateTime?
  created_at DateTime  @default(now())

  // Foreign Keys
  user_id Int

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}
