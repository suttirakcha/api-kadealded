generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  CUSTOMER
  SELLER
}

enum DealStatus {
  PRE_OPEN
  OPEN
  COMPLETED
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PaymentMethod {
  QR
  TRANSFER
  CARD
}

enum ParticipationStatus {
  JOINED
  CANCELLED
}

enum CoinTransactionType {
  TOPUP
  JOIN_USE
  EXPIRED_FORFEIT
}

enum OtpType {
  VERIFY_EMAIL
  FORGOT_PASSWORD
}

model User {
  id             String    @id @default(uuid())
  first_name     String
  last_name      String
  tel_number     String
  email          String    @unique
  password       String
  role           Role      @default(CUSTOMER)
  birth_date     DateTime?
  coin           Int       @default(0)
  trust_score_id Int?
  profile_image  String?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  refreshToken   String?   @unique

  notifications   NotificationTable[]
  trustScores     TrustScore[]
  createdDeals    Deal[]              @relation("CreatedDeals")
  updatedDeals    Deal[]              @relation("UpdatedDeals")
  createdTiers    PriceTier[]         @relation("CreatedPriceTiers")
  updatedTiers    PriceTier[]         @relation("UpdatedPriceTiers")
  createdPayments Payment[]
  joinDeals       JoinDeal[]          @relation("UserJoinDeals")
  coinTransaction CoinTransaction[]
  qrCode          QrCode[]

  @@map("users")
}

model CoinTransaction {
  id         String              @id @default(uuid())
  user_id    String
  amount     Int
  type       CoinTransactionType
  created_at DateTime            @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("coin_transactions")
}

model Seller {
  id         String   @id @default(uuid())
  name       String
  email      String
  tel_number String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  deals Deal[]

  @@map("sellers")
}

model Category {
  id         String   @id @default(uuid())
  name       String   @unique
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  deals Deal[]

  @@map("categories")
}

model Deal {
  id          String     @id @default(uuid())
  title       String
  description String
  deal_status DealStatus @default(PRE_OPEN)
  start_at    DateTime
  deadline    DateTime
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  category_id String
  seller_id   String
  creator     String
  updater     String?

  category      Category    @relation(fields: [category_id], references: [id])
  seller        Seller?     @relation(fields: [seller_id], references: [id])
  createdByUser User        @relation("CreatedDeals", fields: [creator], references: [id])
  updatedByUser User?       @relation("UpdatedDeals", fields: [updater], references: [id])
  pricetiers    PriceTier[]
  joindeals     JoinDeal[]
  images        Image[]

  @@map("deals")
}

model PriceTier {
  id               String   @id @default(uuid())
  min_participants Int
  price            Float
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  deal_id String
  creator String
  updater String?

  deal          Deal  @relation(fields: [deal_id], references: [id])
  createdByUser User  @relation("CreatedPriceTiers", fields: [creator], references: [id])
  updatedByUser User? @relation("UpdatedPriceTiers", fields: [updater], references: [id])

  @@map("pricetiers")
}

model JoinDeal {
  id                   String              @id @default(uuid())
  participation_status ParticipationStatus
  max_participants     Int
  notes                String?
  joined_at            DateTime            @default(now())
  confirm_at           DateTime?
  paid_at              DateTime?
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  user_id String
  deal_id String

  user     User      @relation("UserJoinDeals", fields: [user_id], references: [id])
  deal     Deal      @relation(fields: [deal_id], references: [id])
  payments Payment[] @relation("JoinDealPayments")

  @@map("joindeals")
}

model Payment {
  id             String        @id @default(uuid())
  amount         Float
  payment_method PaymentMethod
  payment_status PaymentStatus @default(PENDING)
  created_at     DateTime      @default(now())

  creator String

  createdByUser  User             @relation(fields: [creator], references: [id])
  paymentHistory PaymentHistory[] @relation("PaymentHistories")

  joinDeal     JoinDeal? @relation("JoinDealPayments", fields: [join_deal_id], references: [id])
  join_deal_id String?

  @@map("payments")
}

model PaymentHistory {
  id             String        @id @default(uuid())
  amount         Float
  payment_status PaymentStatus
  notes          String?
  created_at     DateTime      @default(now())

  payment_id String

  payment Payment @relation("PaymentHistories", fields: [payment_id], references: [id])

  @@map("payment_history")
}

model TrustScore {
  id         String   @id @default(uuid())
  change     Int
  reason     String
  created_at DateTime @default(now())

  user_id String

  user User @relation(fields: [user_id], references: [id])

  @@map("trust_scores")
}

model NotificationTable {
  id         String    @id @default(uuid())
  title      String
  message    String
  read_at    DateTime?
  created_at DateTime  @default(now())

  user_id String

  user User @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model Otp {
  id         String   @id @default(uuid())
  email      String
  otp_code   String
  otp_type   OtpType
  used       Boolean  @default(false)
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([email])
}

model Image {
  id        String  @id @default(uuid())
  image_url String
  deal      Deal?   @relation(fields: [dealId], references: [id])
  dealId    String?
}

model ContactMessage {
  id         String   @id @default(uuid())
  name       String
  email      String
  tel_number String
  message    String
  created_at DateTime @default(now())
  is_read    Boolean  @default(false)
}

model QrCode {
  id         String    @id @default(uuid())
  token      String
  user       User?     @relation(fields: [userId], references: [id])
  userId     String?
  created_at DateTime  @default(now())
  expired_at DateTime?
  isUsed     Boolean   @default(false)
}
